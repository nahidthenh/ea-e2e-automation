# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# WordPress
WP_PORT=8888
WP_URL=http://localhost:8888
WP_TITLE=EA E2E Test Site
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin123
WP_ADMIN_EMAIL=admin@example.com
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=false

# Plugin source directory (absolute path on host machine)
EA_PLUGINS_PATH=/Users/your-username/ea-plugins

# Playwright
BASE_URL=http://localhost:8888
CREATIVE_BUTTON_PAGE_SLUG=creative-button-demo
CODE_SNIPPET_PAGE_SLUG=code-snippet
INFO_BOX_PAGE_SLUG=info-box
COUNTER_PAGE_SLUG=counter
PROGRESS_BAR_PAGE_SLUG=progress-bar
FLIP_BOX_PAGE_SLUG=flip-box

# Slack notifications (local runs — remove or leave blank to disable)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=